{
  "name": "rimworld-auto-ai-translation-cloud-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "d1:inspect": "wrangler d1 execute YOUR_D1_DATABASE_NAME --remote --file d1-tools/inspect-existing-registry.sql",
    "d1:rbac": "wrangler d1 execute YOUR_D1_DATABASE_NAME --remote --file migrations/0001_add_rbac_tables.sql",
    "d1:rwmod": "wrangler d1 execute YOUR_D1_DATABASE_NAME --remote --file migrations/0004_add_rwmod_catalog_tables.sql",
    "d1:rwmod:seed-preview": "wrangler d1 execute YOUR_D1_DATABASE_NAME --remote --file d1-tools/preview-rwmod-seed-from-registry.sql",
    "d1:rwmod:seed": "wrangler d1 execute YOUR_D1_DATABASE_NAME --remote --file d1-tools/seed-rwmod-from-registry.sql",
    "rwmod:local-smoke": "node d1-tools/local-rwmod-smoke.mjs",
    "rwmod:frontier-worker-preview": "node ../../web/rwmod-frontier/preview-server.mjs --worker",
    "rwmod:frontier-worker-smoke": "node d1-tools/frontier-worker-preview-smoke.mjs",
    "rwmod:unified-assets-smoke": "node d1-tools/unified-worker-assets-smoke.mjs"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
